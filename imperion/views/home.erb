<!DOCTYPE html>
<html lang="id">
<head>
  <meta name="google-site-verification" content="WJKJIGiIvHIExnRtKqe0w7XyJZnMa1nBn9k5Y2boKww" />
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Imperion - Game Downloads</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

  <style>
    :root{
      --bg:#0b0f14;
      --card:#121821;
      --soft:#1b2430;
      --accent:#00fff7;
      --text:#e6edf3;
      --muted:#9aa4b2;
    }

    *{margin:0;padding:0;box-sizing:border-box;font-family:Segoe UI,system-ui}

    body{background:var(--bg);color:var(--text)}

    /* NAVBAR */
    nav{
      position:sticky;top:0;z-index:10;
      display:flex;justify-content:space-between;align-items:center;
      padding:14px 32px;
      background:#0f141b;
      border-bottom:1px solid #1f2937;
    }

    .logo{font-size:22px;font-weight:700;color:var(--accent);letter-spacing:1px}

    nav ul{list-style:none;display:flex;gap:26px}
    nav a{color:var(--text);text-decoration:none;font-size:14px;opacity:.9}
    nav a:hover{color:var(--accent)}

    .login-icon{font-size:20px;color:var(--accent)}

    /* HERO COMPACT */
    .hero{
      padding:60px 20px 40px;
      text-align:center;
      border-bottom:1px solid #1f2937;
      background:linear-gradient(180deg,#0b0f14,#0e131a);
    }

    .hero h1{font-size:36px;color:var(--accent);margin-bottom:10px}
    .hero p{color:var(--muted);margin-bottom:22px}

    .btn{
      background:var(--accent);
      color:#001414;
      padding:10px 26px;
      border:none;border-radius:6px;
      font-weight:600;cursor:pointer;
      text-decoration:none;display:inline-block;
    }

    /* SECTION TITLE */
    .section-title{
      padding:28px 32px 0;
      font-size:18px;
      color:var(--muted);
    }

    /* GRID */
    .games{
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
      gap:18px;
      padding:20px 32px 50px;
    }

    .game-card{
      background:var(--card);
      border:1px solid #1f2937;
      border-radius:12px;
      overflow:hidden;
      transition:.2s ease;
      display:flex;flex-direction:column;
    }

    .game-card:hover{transform:translateY(-4px);border-color:var(--accent)}

    .game-card img{width:100%;height:150px;object-fit:cover}

    .info{padding:14px;flex:1;display:flex;flex-direction:column}

    .info h3{font-size:15px;color:var(--accent);margin-bottom:6px}
    .info p{font-size:13px;color:var(--muted);margin-bottom:12px}

    .info button{
      margin-top:auto;
      background:var(--accent);
      border:none;border-radius:6px;
      padding:8px;font-weight:600;cursor:pointer;
    }

    /* FOOTER */
    footer{
      text-align:center;
      padding:20px;
      border-top:1px solid #1f2937;
      color:var(--muted);
      font-size:13px;
    }

    @media(max-width:768px){
      nav ul{display:none}
    }
  </style>
</head>

<body>

<nav>
  <div class="logo">Imperion</div>
  <ul>
    <li><a href="/">Home</a></li>
    <li><a href="/Games">Games</a></li>
    <li><a href="/top-download">Top Downloads</a></li>
    <li><a href="/about">About</a></li>
    <li><a href="/kontak">Contact</a></li>
  </ul>
  <a href="/akun" class="login-icon"><i class="fas fa-user"></i></a>
</nav>

<section class="hero">
  <h1>Imperion Game Hub</h1>
  <p>Download game favorit dengan cepat, bersih, dan modern.</p>
  <a href="/Games" class="btn">Browse Games</a>
</section>

<div class="section-title">Game Terpopuler</div>

<section class="games">
  <div class="game-card">
    <img src="/gambar/galdius quest.jpg.jpeg" alt="Gladius Quest">
    <div class="info">
      <h3>Gladius Quest</h3>
      <p>RPG • Adventure • 1.2GB</p>
      <button>Download</button>
    </div>
  </div>

  <div class="game-card">
    <img src="/gambar/arcana.jpg.jpeg" alt="Arcana Battle">
    <div class="info">
      <h3>Arcana Battle</h3>
      <p>Strategy • Fantasy • 900MB</p>
      <button>Download</button>
    </div>
  </div>

  <div class="game-card">
    <img src="/gambar/images.jpeg" alt="Imperion Arena">
    <div class="info">
      <h3>Imperion Arena</h3>
      <p>Action • Multiplayer • 2GB</p>
      <button>Download</button>
    </div>
  </div>
</section>

<footer>
  © 2026 Imperion. All rights reserved.
</footer>

</body>
</html>
