        }

        .game-card:hover {
            transform: scale(1.03);
            border-color: #a00000;
            box-shadow: 0 0 18px #520000;
        }

        .game-card img {
            width: 100%;
            height: 180px;
            object-fit: cover;
            border-bottom: 1px solid #300;
        }

        .info {
            padding: 15px;
        }

        .info h3 {
            margin: 0;
            font-size: 22px;
            color: #ff3b3b;
            text-shadow: 0 0 6px #7a0000;
        }

        .info p {
            font-size: 14px;
            margin: 8px 0 12px;
            color: #bdbdbd;
        }

        .rune {
            font-size: 16px;
            color: #ff2323;
            margin-right: 6px;
        }

        .btn-download {
            display: inline-block;
            padding: 9px 15px;
            background: #a10000;
            color: white;
            font-weight: bold;
            border-radius: 6px;
            text-decoration: none;
            box-shadow: 0 0 8px #600000;
            transition: 0.25s ease;
        }

        .btn-download:hover {
            background: #ff3b3b;
