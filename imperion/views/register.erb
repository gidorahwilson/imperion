<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Imperion Register - Yautja Edition</title>

<style>
/* ---------------- GLOBAL ---------------- */
body {
    margin: 0;
    height: 70vh;
    font-family: 'Poppins', sans-serif;
    background: url("https://cdn.3axis.co/user-images/pok92j7j.png") no-repeat center center/cover;
    display: flex;
    justify-content: center;
    align-items: center;
    overflow: hidden;
}

/* ------ Neon Grid Animation Background ------ */
.neon-grid {
    position: absolute;
    width: 200%;
    height: 200%;
    background: repeating-linear-gradient(
        0deg,
        rgba(0,255,255,0.05) 0px,
        rgba(0,255,255,0.05) 2px,
        transparent 2px,
        transparent 40px
    ),
    repeating-linear-gradient(
        90deg,
        rgba(0,255,255,0.05) 0px,
        rgba(0,255,255,0.05) 2px,
        transparent 2px,
        transparent 40px
    );
    animation: gridMove 25s linear infinite;
}

@keyframes gridMove {
    from { transform: translate(0,0) rotate(0deg); }
    to   { transform: translate(-200px,-200px) rotate(1deg); }
}

/* ---------------- REGISTER BOX ---------------- */
.register-box {
    position: relative;
    width: 380px;
    padding: 40px;
    background: rgba(0, 0, 0, 0.78);
    border-radius: 15px;
    border: 1px solid rgba(0,255,255,0.4);
    box-shadow: 0 0 18px rgba(0,255,255,0.5);
    backdrop-filter: blur(6px);
    animation: fadeIn 1.2s ease;
}

/* ---------- Animated Border Glow ------------- */
.register-box::before {
    content: "";
    position: absolute;
    inset: -3px;
    border-radius: 15px;
    background: linear-gradient(120deg, #00ffff, #0088ff, #00ffff);
    z-index: -1;
    filter: blur(15px);
    animation: glowSpin 6s linear infinite;
}

@keyframes glowSpin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
}

/* ---------------- TITLE ---------------- */
.logo {
    text-align: center;
    color: #00f0ff;
    font-size: 30px;
    font-weight: 900;
    letter-spacing: 3px;
    text-shadow: 0 0 12px #00eaff;
}

.register-box h2 {
    text-align: center;
    color: #fff;
    margin-bottom: 25px;
    text-shadow: 0 0 10px #00faff;
}

/* ---------------- FORM ---------------- */
.input-group {
    margin-bottom: 20px;
}

.input-group label {
    display: block;
    color: #00eaff;
    font-size: 14px;
    margin-bottom: 5px;
    text-shadow: 0 0 7px #00faff;
}

.input-group input {
    width: 100%;
    padding: 12px;
    border-radius: 8px;
    border: 1px solid #00faff;
    background: rgba(0,0,0,0.4);
    color: #fff;
    font-size: 15px;
    outline: none;
}

.input-group input:focus {
    border-color: #00ffff;
    box-shadow: 0 0 12px #00faff;
}

/* ---------------- BUTTON ---------------- */
.btn {
    width: 100%;
    padding: 12px;
    background: #00eaff;
    color: #000;
    border: none;
    border-radius: 8px;
    font-size: 16px;
    font-weight: bold;
    cursor: pointer;
    letter-spacing: 1px;
    transition: 0.25s;
    text-transform: uppercase;
}

.btn:hover {
    background: #00b3c4;
    box-shadow: 0 0 15px #00faff;
}

/* ---------------- LINK ---------------- */
.login-link {
    margin-top: 15px;
    text-align: center;
    color: #00eaff;
}

.login-link a {
    color: #00eaff;
    text-decoration: none;
    font-weight: bold;
}

.login-link a:hover {
    text-shadow: 0 0 10px #00faff;
}

/* ---------------- Animasi FadeIn ---------------- */
@keyframes fadeIn {
    from { opacity: 0; transform: scale(0.92); }
    to   { opacity: 1; transform: scale(1); }
}

</style>
</head>


<body>

<div class="neon-grid"></div>

<div class="register-box">
    <div class="logo">IMPERION</div>
    <h2>Registration</h2>

    <form action="/register-user" method="POST">

        <div class="input-group">
            <label>Full Name</label>
            <input type="text" name="name" placeholder="Enter your name" required>
        </div>

        <div class="input-group">
            <label>Email Address</label>
            <input type="email" name="email" placeholder="Enter your email" required>
        </div>

        <button class="btn">Create Account</button>

    </form>

    <div class="login-link">
        Already a warrior? <a href="/akun">Login</a>
    </div>
</div>

</body>
</html>
